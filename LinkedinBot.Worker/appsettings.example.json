{
  "LinkedIn": {
    "Email": "your-email@example.com",
    "Password": "your-linkedin-password"
  },
  "OpenAI": {
    "ApiKey": "sk-proj-your-openai-api-key-here",
    "Model": "gpt-4o"
  },
  "JobSearch": {
    "Keywords": "(.NET OR C#) AND NOT Java",
    "GeoId": "106057199",
    "Distance": 25,
    "ExperienceLevel": "4",
    "EasyApply": true,
    "RemoteFilter": "2",
    "MaxApplicationsPerRun": 50,
    "SearchIntervalMinutes": 5,
    "SalaryExpectation": 15000,
    "MaxFormSteps": 20,
    "InteractivePrompt": false
  },
  "JobHistory": {
    "Provider": "postgres"
  },
  "ConnectionStrings": {
    "JobHistory": "Host=postgres;Database=linkedinbot;Username=linkedinbot;Password=linkedinbot"
  },
  "Browser": {
    "Locale": "pt-BR",
    "Headless": true,
    "SlowMo": 500,
    "UserDataDir": "./user-data",
    "Channel": "chromium"
  },
  "Resume": {
    "MarkdownPath": "./resume.md"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/worker-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
